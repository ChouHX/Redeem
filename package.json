{
  "name": "outlook-manager-node-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter ui run build",
    "dev": "concurrently -k -n server,ui -c blue,magenta \"pnpm run dev:server\" \"pnpm run dev:ui\"",
    "dev:server": "node --watch src/server.js",
    "dev:ui": "pnpm --filter ui run dev",
    "dev:mail-tauri": "pnpm --filter mail-tauri run dev",
    "mail-tauri:build": "pnpm --filter mail-tauri run build",
    "mail-tauri:build:linux": "pnpm --filter mail-tauri run build:linux",
    "mail-tauri:build:windows": "pnpm --filter mail-tauri run build:windows",
    "mail-tauri:build:windows:installer": "pnpm --filter mail-tauri run build:windows:installer",
    "package:docker": "bash ./scripts/package-docker-bundle.sh",
    "ui:dev": "pnpm --filter ui run dev",
    "ui:build": "pnpm --filter ui run build",
    "start": "node src/server.js",
    "test": "node --test"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "multer": "^2.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
